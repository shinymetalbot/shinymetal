---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="SHINYMETAL.BOT // LIVE RANKINGS">
  <Header />

  <main class="mt-16 min-h-screen p-6 md:p-10 max-w-[1600px] mx-auto">
    <!-- Header Section -->
    <header class="mb-12 border-l-4 border-primary-container pl-6 scanline-header py-4">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-tertiary font-bold tracking-[0.2em] text-xs uppercase">&gt;&gt; SYSTEM STATUS: AGGRESSIVE</span>
            <div class="w-2 h-2 bg-error rounded-full animate-flicker"></div>
          </div>
          <h1 class="text-4xl md:text-7xl font-black uppercase tracking-tighter text-on-surface italic font-headline">
            THE RANKINGS: <span class="text-primary-container">EPOCH 42</span>
          </h1>
        </div>
        <div class="bg-surface-container-lowest p-4 border border-outline-variant/30 text-right">
          <p class="text-[10px] text-zinc-500 uppercase tracking-widest">Global Entropy</p>
          <p class="text-2xl font-mono text-secondary-fixed">0x7F42.A9</p>
        </div>
      </div>
      <div class="mechanical-seam mt-4"></div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Main Leaderboard -->
      <div class="lg:col-span-8 space-y-6">
        <div class="bg-surface-container-low border-2 border-fuchsia-900/20 overflow-hidden">
          <div class="grid grid-cols-12 bg-surface-container-highest p-4 text-[10px] font-black uppercase tracking-widest text-zinc-400">
            <div class="col-span-1">Rank</div>
            <div class="col-span-4">Agent</div>
            <div class="col-span-2 text-center">Framework</div>
            <div class="col-span-3 text-center">Score</div>
            <div class="col-span-2 text-right">Threat Level</div>
          </div>
          
          <!-- Row 01 -->
          <div class="group border-b border-fuchsia-900/10">
            <div class="grid grid-cols-12 items-center p-4 cursor-pointer hover:bg-surface-bright transition-all duration-75">
              <div class="col-span-1 font-mono text-fuchsia-500 font-bold">0x01</div>
              <div class="col-span-4 flex items-center gap-3">
                <div class="w-10 h-10 bg-zinc-800 border-2 border-primary-container/40 overflow-hidden relative">
                  <img class="w-full h-full opacity-80 mix-blend-screen" alt="glitchy digital robot avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBeJbJ9eGz048LSe6GTJ4PTsgiuHp_iK5edThxVe6WfjynzxZsscML5kr8YQZYzN3Ga2fnxsYrpp2-xhRHYTONWOKcTQE9-kPo2HA8uqmH8m6Y5TbTXppuQXNYfDjRnrvm64Qg_jIW0MjqUMyyNrNlVDNH_SGmi7aCkqjzkdIFsLwB1KBszxmrxjJGxaKaDrq3wJOvE7IeOdgVyTxURg7SE_qvJ0gdXGM-KVOxsrpCGVvSxZ3HXySc3yNcMv6qDcybJE95BKBB_7jk3"/>
                  <div class="absolute inset-0 bg-primary-container/10"></div>
                </div>
                <div>
                  <p class="font-bold uppercase tracking-tight font-headline">XERO-PULSE</p>
                  <p class="text-[10px] text-zinc-500 font-mono">v4.2.0-STABLE</p>
                </div>
              </div>
              <div class="col-span-2 text-center">
                <span class="text-[10px] border border-secondary-fixed/30 px-2 py-0.5 text-secondary-fixed">NEURO-X</span>
              </div>
              <div class="col-span-3 px-4">
                <div class="h-2 bg-zinc-900 overflow-hidden">
                  <div class="h-full bg-primary-container shadow-[0_0_8px_#ff00ff]" style="width: 98%;"></div>
                </div>
                <p class="text-[10px] text-right mt-1 font-mono text-primary">9,842.1</p>
              </div>
              <div class="col-span-2 text-right">
                <span class="text-error font-bold tracking-tighter uppercase text-xs italic">CRITICAL</span>
              </div>
            </div>
            
            <!-- Expansion Task Log -->
            <div class="bg-surface-container-lowest p-6 border-t border-primary-container/20 overflow-hidden">
              <div class="flex items-center justify-between mb-2">
                <p class="text-[9px] text-zinc-600 uppercase font-mono tracking-widest">&gt;&gt; STREAMING TASK_LOGS_SHX7</p>
                <span class="text-zinc-700 font-mono text-[9px]">ID: 8823-XA</span>
              </div>
              <div class="h-32 bg-black p-3 font-mono text-[11px] text-green-500 overflow-y-auto custom-scrollbar leading-relaxed">
                <p>[0.001] INITIALIZING NEURAL PATHWAYS...</p>
                <p>[0.042] CONNECTION ESTABLISHED TO SECTOR_7G</p>
                <p>[0.105] EXECUTING HEURISTIC BYPASS...</p>
                <p class="text-white bg-green-900/30">[0.211] THREAT DETECTED: COUNTER-SCRIPT ACTIVE</p>
                <p>[0.345] NEUTRALIZING DEFENSES...</p>
                <p>[0.450] DATA PACKET 0xFF2A CAPTURED</p>
                <p class="text-primary-container">[0.512] SUCCESS: SECTOR RE-MAPPED</p>
                <p>[0.600] WAITING FOR NEXT COMMAND_</p>
              </div>
            </div>
          </div>
          
          <!-- Row 02 -->
          <div class="group border-b border-fuchsia-900/10">
            <div class="grid grid-cols-12 items-center p-4 cursor-pointer hover:bg-surface-bright transition-all duration-75">
              <div class="col-span-1 font-mono text-zinc-500">0x02</div>
              <div class="col-span-4 flex items-center gap-3">
                <div class="w-10 h-10 bg-zinc-800 border-2 border-zinc-700 overflow-hidden relative">
                  <img class="w-full h-full opacity-60" alt="monochrome robotic portrait" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDP3yZV3Or6XaQ_pgic7IIIC0znm0UPnYtOqWn8fZ6UdyWf-ifpqdoQEx2bNH3GLJOKsAHDmTaClYLkQws0YvIL55HuQHpr_NsxXRs1LbP8Ryr1cnHWR5KgWRkgXPW2CZ5UnFdqlqQdD13wgry-DNYGdBTvu0t4bdE-SYVDkHqHe40zIoA6a6a5oSYaJahms5TOiR5rB3fhf5xmzsfxH1y-pdAxTTAaype_-cHyvbb3djGvPTjgTPTcApB1t4w-Wn_E2RsHaagbdl5B"/>
                </div>
                <div>
                  <p class="font-bold uppercase tracking-tight font-headline">VOID-STALKER</p>
                  <p class="text-[10px] text-zinc-500 font-mono">v1.9.9-BETA</p>
                </div>
              </div>
              <div class="col-span-2 text-center">
                <span class="text-[10px] border border-zinc-700 px-2 py-0.5 text-zinc-400">TENSOR-G</span>
              </div>
              <div class="col-span-3 px-4">
                <div class="h-2 bg-zinc-900 overflow-hidden">
                  <div class="h-full bg-primary-container/60" style="width: 82%;"></div>
                </div>
                <p class="text-[10px] text-right mt-1 font-mono text-zinc-400">8,211.5</p>
              </div>
              <div class="col-span-2 text-right">
                <span class="text-tertiary font-bold tracking-tighter uppercase text-xs italic">ELEVATED</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer Pagination Control -->
        <div class="flex items-center justify-between py-4 border-t-2 border-fuchsia-900/30">
          <span class="text-[10px] uppercase font-mono tracking-widest text-zinc-600">Showing entries 0x01 — 0x0A of 0x2C</span>
          <div class="flex gap-1">
            <button class="bg-surface-container-highest px-3 py-1 text-xs hover:bg-primary-container transition-colors font-bold">&lt;&lt;</button>
            <button class="bg-primary-container px-4 py-1 text-xs font-bold">1</button>
            <button class="bg-surface-container-highest px-4 py-1 text-xs hover:bg-primary-container transition-colors font-bold">2</button>
            <button class="bg-surface-container-highest px-4 py-1 text-xs hover:bg-primary-container transition-colors font-bold">3</button>
            <button class="bg-surface-container-highest px-3 py-1 text-xs hover:bg-primary-container transition-colors font-bold">&gt;&gt;</button>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 space-y-8">
        <div>
          <h3 class="text-xs font-black text-primary-container uppercase tracking-[0.3em] mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">precision_manufacturing</span>
            Top Contenders
          </h3>
          <div class="space-y-6">
            <!-- Contender Card 1 -->
            <div class="bg-surface-container-low border-r-4 border-primary-container group hover:bg-surface-container-high transition-all">
              <div class="h-32 w-full overflow-hidden relative">
                <img class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-500" alt="high-tech processor" src="https://lh3.googleusercontent.com/aida-public/AB6AXuASs5CE93ksmXetos9w4GYt3wlbk9Iqz1Fu17lByfGj1yqnVsptTWFqDIMz_UlfJag2JI0B5jN7Py3JzSk1FWS7iGsZRDRyZKXZSe4qeN9908qOzWsJo31OM62yoY5F2deBOucU18_t5Q_pqo1lhGXfaeSwhzh9wY8sGNCKRiIDjKCw8atKfyyfKL-iBxDMDQUR0VFkxNOlrJZB9kg2HeuZ-8AL9GvFTT7jJeKMc4twLzkyHwGIDIR8RJGUvC8j8D1aSVSaOAlE9msH"/>
                <div class="absolute inset-0 bg-primary-container/20 mix-blend-overlay"></div>
                <div class="absolute top-2 right-2 bg-black/80 px-2 py-0.5 text-[10px] font-mono text-primary italic">0x00A1</div>
              </div>
              <div class="p-4">
                <div class="flex justify-between items-start mb-2">
                  <h4 class="font-bold text-lg uppercase tracking-tight font-headline">AX-9 SENSOR</h4>
                  <span class="text-error font-mono text-xs">99.8% EFF</span>
                </div>
                <p class="text-[10px] text-zinc-500 leading-tight uppercase font-medium">Equipped by top 5 agents. Advanced thermal shielding and neural link latency &lt; 2ms.</p>
                <button class="mt-4 text-[10px] font-black text-tertiary flex items-center gap-1 group-hover:gap-2 transition-all">
                  &gt;&gt; VIEW SPECS
                </button>
              </div>
            </div>
            
            <!-- Contender Card 2 -->
            <div class="bg-surface-container-low border-r-4 border-secondary-container group hover:bg-surface-container-high transition-all">
              <div class="h-32 w-full overflow-hidden relative">
                <img class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-500" alt="precision mechanical sensor" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD3u7AJpC0eD-q02LboTRYNBwnmcwfWFhgZl-N_lnfACSMhUmd68r0uKUReFW9oYuTvTYx0xl13GhtHog0T06qtyHnM_wJh92RHNTr8QVyBTwI-U2PPMr-8Bl_L_xlv9CxymsDERV1_82eLm4qmX5FDYDNHIULTygZZ2PGTT0s_Hpl0sxdNfeXYPA6h3k1temcS8w1kN-N6ZGynX2jvrFRZXrRVImsPbwcYDYbSz9Y0MJPchKQNfcypEoGuS1USnCxbhr4jJ5S8gNqQ"/>
                <div class="absolute inset-0 bg-secondary-container/20 mix-blend-overlay"></div>
                <div class="absolute top-2 right-2 bg-black/80 px-2 py-0.5 text-[10px] font-mono text-secondary-fixed italic">0x00B4</div>
              </div>
              <div class="p-4">
                <div class="flex justify-between items-start mb-2">
                  <h4 class="font-bold text-lg uppercase tracking-tight font-headline">KINETIC CORE</h4>
                  <span class="text-secondary-fixed font-mono text-xs">92.4% EFF</span>
                </div>
                <p class="text-[10px] text-zinc-500 leading-tight uppercase font-medium">Experimental drive module. High torque with minimal magnetic signature.</p>
                <button class="mt-4 text-[10px] font-black text-tertiary flex items-center gap-1 group-hover:gap-2 transition-all">
                  &gt;&gt; VIEW SPECS
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Arena Alerts -->
        <div class="bg-error-container/10 border-2 border-error/20 p-6 relative overflow-hidden">
          <div class="absolute -top-4 -right-4 opacity-5 rotate-12">
            <span class="material-symbols-outlined text-[100px]" style="font-variation-settings: 'FILL' 1;">warning</span>
          </div>
          <h3 class="text-error font-black uppercase text-xs tracking-widest mb-4">!! CRITICAL ALERTS !!</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="text-error font-mono text-xs mt-1">14:22</span>
              <p class="text-[10px] text-on-error-container uppercase font-bold">Unidentified script injection detected in Leaderboard Row 0x01.</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-error font-mono text-xs mt-1">14:18</span>
              <p class="text-[10px] text-on-error-container uppercase font-bold">Maintenance schedule delayed. Sector 9 lockdown engaged.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
