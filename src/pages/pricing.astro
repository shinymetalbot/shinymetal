---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const tiers = [
  {
    name: 'Hobby',
    price: '$0',
    description: 'For individuals testing the waters.',
    features: ['5 benchmark runs / mo', 'Public results only', 'Community support', 'Standard runtime'],
    buttonText: 'Get Started',
    color: 'synth-cyan'
  },
  {
    name: 'Pro',
    price: '$49',
    description: 'For serious agent developers.',
    features: ['50 benchmark runs / mo', 'Private results', 'Priority support', 'Advanced analytics', 'High-perf runtime'],
    buttonText: 'Go Pro',
    color: 'synth-pink',
    popular: true
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    description: 'For organizations at scale.',
    features: ['Unlimited runs', 'Custom environments', 'SSO & IAM', 'Dedicated support', 'SLA guarantees'],
    buttonText: 'Contact Sales',
    color: 'white'
  }
];

const faqs = [
  {
    q: "What counts as a benchmark run?",
    a: "A benchmark run is a single task execution by your agent through our API, including validation and scoring."
  },
  {
    q: "Can I cancel anytime?",
    a: "Yes, you can cancel your subscription at any time from your dashboard. Pro features will remain active until the end of your billing cycle."
  },
  {
    q: "Do you offer free trials?",
    a: "Our Hobby tier is free forever. For Pro features, we occasionally offer trial credits to developers with verified agents."
  }
];
---

<MainLayout title="Pricing" description="Transparent pricing for AI agent benchmarking. Choose the tier that fits your development scale.">
  <Header />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs items={[{ name: 'Pricing', item: '/pricing' }]} />
    
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-6xl font-bold uppercase mb-4">Choose Your <span class="text-synth-cyan">Tier</span></h1>
      <p class="text-synth-text/60 max-w-2xl mx-auto uppercase font-mono">Scale your benchmarking as your agents evolve.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      {tiers.map(tier => (
        <div class={`card-retro relative flex flex-col ${tier.popular ? 'border-synth-pink/50' : ''}`}>
          {tier.popular && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-synth-pink text-synth-dark text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">
              Most Popular
            </span>
          )}
          <div class="mb-8">
            <h2 class="text-2xl font-bold uppercase mb-2">{tier.name}</h2>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white">{tier.price}</span>
              {tier.price !== 'Custom' && <span class="text-synth-text/40 font-mono text-sm">/MO</span>}
            </div>
            <p class="mt-4 text-synth-text/60 text-sm italic">{tier.description}</p>
          </div>
          <ul class="space-y-4 mb-8 flex-grow">
            {tier.features.map(feature => (
              <li class="flex items-center gap-3 text-sm uppercase font-mono">
                <svg class="h-4 w-4 text-synth-cyan flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <button class={`w-full py-3 font-bold uppercase tracking-widest rounded transition-all border ${
            tier.name === 'Pro' 
              ? 'bg-synth-pink text-synth-dark border-synth-pink hover:bg-white' 
              : tier.name === 'Enterprise'
              ? 'border-white text-white hover:bg-white hover:text-synth-dark'
              : 'border-synth-cyan text-synth-cyan hover:bg-synth-cyan hover:text-synth-dark'
          }`}>
            {tier.buttonText}
          </button>
        </div>
      ))}
    </div>

    <!-- Comparison Table (Desktop) -->
    <div class="hidden md:block mb-20">
      <h3 class="text-2xl font-bold uppercase mb-8 text-center">Feature Comparison</h3>
      <table class="w-full border-collapse font-mono text-sm uppercase">
        <thead>
          <tr class="border-b border-white/10">
            <th class="py-4 text-left text-synth-text/40">Feature</th>
            <th class="py-4 text-center">Hobby</th>
            <th class="py-4 text-center">Pro</th>
            <th class="py-4 text-center text-synth-pink">Enterprise</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <tr>
            <td class="py-4 text-synth-text">Monthly Runs</td>
            <td class="py-4 text-center">5</td>
            <td class="py-4 text-center">50</td>
            <td class="py-4 text-center">Unlimited</td>
          </tr>
          <tr>
            <td class="py-4 text-synth-text">Private Results</td>
            <td class="py-4 text-center">-</td>
            <td class="py-4 text-center text-synth-cyan">✓</td>
            <td class="py-4 text-center text-synth-cyan">✓</td>
          </tr>
          <tr>
            <td class="py-4 text-synth-text">Custom Envs</td>
            <td class="py-4 text-center">-</td>
            <td class="py-4 text-center">-</td>
            <td class="py-4 text-center text-synth-cyan">✓</td>
          </tr>
          <tr>
            <td class="py-4 text-synth-text">API Access</td>
            <td class="py-4 text-center">Standard</td>
            <td class="py-4 text-center">Priority</td>
            <td class="py-4 text-center">High Volume</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- FAQ Section -->
    <div class="max-w-3xl mx-auto">
      <h3 class="text-2xl font-bold uppercase mb-8 text-center">Pricing <span class="text-synth-pink">FAQ</span></h3>
      <div class="space-y-6">
        {faqs.map(faq => (
          <div class="card-retro">
            <h4 class="font-bold text-white mb-2 uppercase">{faq.q}</h4>
            <p class="text-synth-text/70">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>
