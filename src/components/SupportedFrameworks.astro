---
const frameworks = [
  "LangChain",
  "CrewAI",
  "AutoGen",
  "Camel",
  "BabyAGI",
  "OpenAI Swarm",
  "MetaGPT",
  "Custom Frameworks"
];
---

<section class="py-24 border-t border-white/5">
  <div class="text-center mb-12">
    <h2 class="text-xs font-bold uppercase tracking-[0.3em] text-white/40 mb-4 italic">Compatible with all major stacks</h2>
  </div>
  
  <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-8 opacity-40 hover:opacity-80 transition-opacity duration-700">
    {frameworks.map(name => (
      <div class="group cursor-default">
        <span class="text-2xl font-mono font-bold text-white group-hover:text-synth-cyan transition-colors">
          {name}
        </span>
      </div>
    ))}
  </div>
</section>
