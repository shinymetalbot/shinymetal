---
import MainLayout from './MainLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  lastUpdated?: Date;
  category: string;
  tags?: string[];
  author?: string;
  ogImage?: string;
  headings: { depth: number; slug: string; text: string }[];
  faq?: { q: string; a: string }[];
}

const { 
  title, 
  description, 
  date, 
  lastUpdated, 
  category, 
  tags, 
  author = 'ShinyMetal Team', 
  ogImage,
  headings,
  faq
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Structured Data
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://shinymetal.bot"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "https://shinymetal.bot/blog"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": category,
      "item": `https://shinymetal.bot/blog/${category}`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": title
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImage ? [`https://shinymetal.bot${ogImage}`] : ["https://shinymetal.bot/images/og-default.webp"],
  "datePublished": date.toISOString(),
  "dateModified": lastUpdated ? lastUpdated.toISOString() : date.toISOString(),
  "author": [{
    "@type": "Organization",
    "name": author,
    "url": "https://shinymetal.bot"
  }]
};

const faqSchema = faq ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
} : null;

const jsonLd = [breadcrumbSchema, articleSchema];
if (faqSchema) jsonLd.push(faqSchema);
---

<MainLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <div class="max-w-7xl mx-auto px-4 py-12 lg:py-20 relative">
    <nav class="mb-8 text-sm uppercase tracking-widest text-synth-text/60 font-mono">
      <a href="/" class="hover:text-synth-cyan transition-colors">Home</a>
      <span class="mx-2">&gt;</span>
      <a href="/blog" class="hover:text-synth-cyan transition-colors">Blog</a>
      <span class="mx-2">&gt;</span>
      <span class="text-synth-cyan">{category}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-12 lg:gap-12">
      <!-- Sidebar TOC -->
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-12">
          <h2 class="text-xs uppercase tracking-widest text-white/40 mb-4 border-b border-white/10 pb-2">Table of Contents</h2>
          <nav class="space-y-3">
            {headings.filter(h => h.depth <= 3).map(heading => (
              <a 
                href={`#${heading.slug}`} 
                class:list={[
                  "block text-sm hover:text-synth-cyan transition-colors",
                  heading.depth === 3 ? "pl-4 text-synth-text/60" : "text-synth-text"
                ]}
              >
                {heading.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <article class="lg:col-span-9 max-w-none">
        <header class="mb-12">
          <h1 class="text-4xl md:text-5xl lg:text-6xl mb-6 glow-cyan">{title}</h1>
          <div class="flex flex-wrap items-center gap-6 text-sm font-mono text-synth-text/70 uppercase tracking-wider">
            <time datetime={date.toISOString()}>{formattedDate}</time>
            <span class="w-1 h-1 bg-synth-pink rounded-full"></span>
            <span class="text-synth-pink">{category}</span>
            <span class="w-1 h-1 bg-synth-pink rounded-full"></span>
            <span>By {author}</span>
          </div>
        </header>

        <div class="prose prose-invert prose-synth max-w-none 
          prose-headings:font-mono prose-headings:uppercase prose-headings:tracking-tight
          prose-a:text-synth-cyan prose-a:no-underline hover:prose-a:underline
          prose-strong:text-white prose-blockquote:border-synth-cyan prose-blockquote:bg-synth-cyan/5
          prose-code:text-synth-pink prose-pre:border prose-pre:border-white/10">
          <slot />
        </div>

        {faq && (
          <section class="mt-20 pt-12 border-t border-white/10">
            <h2 class="text-2xl mb-8 glow-pink">Frequently Asked Questions</h2>
            <div class="space-y-8">
              {faq.map(item => (
                <div class="card-retro">
                  <h3 class="text-white text-lg mb-2">{item.q}</h3>
                  <p class="text-synth-text/80">{item.a}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <footer class="mt-20 pt-8 border-t border-white/10 flex flex-wrap gap-4 items-center justify-between">
          <div class="flex gap-2">
            {tags?.map(tag => (
              <span class="text-[10px] px-2 py-1 border border-white/20 text-white/50 uppercase tracking-widest">#{tag}</span>
            ))}
          </div>
          <div class="flex gap-4">
            <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="text-xs font-mono uppercase text-synth-cyan hover:glow-cyan transition-all">Back to Top</button>
          </div>
        </footer>
      </article>
    </div>
  </div>
</MainLayout>

<style is:global>
  .prose-synth h2 {
    scroll-margin-top: 2rem;
    @apply border-b border-white/5 pb-2 mb-6 mt-12;
  }
  .prose-synth p {
    @apply mb-6 leading-relaxed;
  }
</style>
