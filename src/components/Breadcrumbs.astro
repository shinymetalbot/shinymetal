---
interface Props {
  items: {
    name: string;
    item: string;
  }[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": `https://shinymetal.bot${item.item}`
  }))
};
---

<nav aria-label="Breadcrumb" class="mb-8 text-sm font-mono">
  <ol class="flex list-none p-0 text-synth-text/60">
    <li class="flex items-center">
      <a href="/" class="hover:text-synth-cyan transition-colors">HOME</a>
      <span class="mx-2">/</span>
    </li>
    {items.map((item, index) => (
      <li class="flex items-center">
        <a href={item.item} class={index === items.length - 1 ? "text-synth-pink uppercase" : "hover:text-synth-cyan transition-colors uppercase"}>
          {item.name}
        </a>
        {index < items.length - 1 && <span class="mx-2">/</span>}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
