---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['all', ...new Set(posts.map(post => post.data.category))];

const title = "Blog";
const description = "Latest insights, benchmarks, and guides from the ShinyMetal.bot team.";
---

<MainLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 py-12 lg:py-20">
    <header class="mb-12">
      <h1 class="text-5xl lg:text-7xl mb-6 glow-cyan">TRANSMISSIONS</h1>
      <p class="text-xl text-synth-text/80 max-w-2xl">{description}</p>
    </header>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-4 mb-12 border-b border-white/10 pb-8">
      {categories.map(cat => (
        <button 
          class:list={[
            "px-6 py-2 border font-mono text-xs uppercase tracking-widest transition-all hover:glow-cyan active:scale-95 filter-btn",
            cat === 'all' ? "border-synth-cyan text-synth-cyan shadow-neon-cyan bg-synth-cyan/10" : "border-white/20 text-white/50 hover:border-synth-cyan/50"
          ]}
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Blog Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="post-grid">
      {posts.map(post => (
        <article 
          class="card-retro group flex flex-col h-full post-card" 
          data-category={post.data.category}
        >
          <div class="flex-1">
            <div class="flex justify-between items-start mb-4">
              <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-synth-pink border border-synth-pink/30 px-2 py-0.5 rounded">
                {post.data.category}
              </span>
              <time class="text-[10px] font-mono text-white/40 uppercase">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })}
              </time>
            </div>
            
            <h2 class="text-2xl mb-4 group-hover:text-synth-cyan transition-colors leading-tight">
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h2>
            
            <p class="text-synth-text/70 text-sm line-clamp-3 mb-6">
              {post.data.description}
            </p>
          </div>

          <a 
            href={`/blog/${post.slug}`} 
            class="mt-auto inline-flex items-center text-[10px] font-mono uppercase tracking-widest text-synth-cyan group-hover:glow-cyan transition-all"
          >
            Read Entry <span class="ml-2 group-hover:translate-x-1 transition-transform">-&gt;</span>
          </a>
        </article>
      ))}
    </div>
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.post-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');

        // Update buttons
        buttons.forEach(b => {
          if (b.getAttribute('data-category') === category) {
            b.classList.add('border-synth-cyan', 'text-synth-cyan', 'shadow-neon-cyan', 'bg-synth-cyan/10');
            b.classList.remove('border-white/20', 'text-white/50');
          } else {
            b.classList.remove('border-synth-cyan', 'text-synth-cyan', 'shadow-neon-cyan', 'bg-synth-cyan/10');
            b.classList.add('border-white/20', 'text-white/50');
          }
        });

        // Filter cards
        cards.forEach(card => {
          const cardCat = card.getAttribute('data-category');
          if (category === 'all' || category === cardCat) {
            (card as HTMLElement).style.display = 'flex';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</MainLayout>
