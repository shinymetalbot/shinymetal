---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Pricing | SHINYMETAL.BOT">
  <Header />
  
  <main class="pt-32 pb-24 px-6 max-w-7xl mx-auto">
    <!-- Header Section -->
    <header class="text-center mb-20">
      <div class="inline-block py-1 px-3 mb-6 bg-surface-container-high rounded-full ghost-border">
        <span class="text-[10px] font-label uppercase tracking-widest text-primary">Deployment ready</span>
      </div>
      <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter mb-6 text-on-surface">
        Forge your path to <span class="text-primary-container">peak performance.</span>
      </h1>
      <p class="font-body text-on-surface-variant max-w-2xl mx-auto text-lg leading-relaxed">
        Precision-engineered infrastructure for the next generation of autonomous agents. Scale from prototype to sovereign swarm.
      </p>
    </header>

    <!-- Pricing Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24">
      <!-- Hobby Tier -->
      <div class="metal-card rounded-xl p-8 flex flex-col glow-overlay">
        <div class="mb-8">
          <span class="font-label text-xs uppercase tracking-widest text-outline">Starter Unit</span>
          <h3 class="font-headline text-3xl font-bold mt-2">Hobby</h3>
        </div>
        <div class="mb-8">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-bold text-on-surface">$0</span>
            <span class="text-on-surface-variant font-label text-sm">/mo</span>
          </div>
        </div>
        <div class="space-y-4 mb-10 flex-grow">
          <div class="flex items-center gap-3 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
            <span>Basic API Access</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
            <span>Public Logs</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-primary text-lg">check_circle</span>
            <span>Up to 5 Daily Tasks</span>
          </div>
        </div>
        <button class="w-full py-3 bg-surface-container-highest border border-outline-variant/15 rounded-lg font-bold text-sm hover:bg-surface-container-high transition-colors">
          Initialize Basic
        </button>
      </div>

      <!-- Pro Tier (Most Popular) -->
      <div class="metal-card rounded-xl p-8 flex flex-col relative border-t-2 border-primary-container glow-overlay overflow-hidden shadow-[0_0_40px_rgba(0,240,255,0.1)]">
        <div class="absolute top-0 right-0 bg-primary-container text-on-primary text-[10px] font-bold px-4 py-1 rounded-bl-lg uppercase tracking-tighter">
          MOST POPULAR
        </div>
        <div class="mb-8">
          <span class="font-label text-xs uppercase tracking-widest text-primary">Advanced Rig</span>
          <h3 class="font-headline text-3xl font-bold mt-2">Pro</h3>
        </div>
        <div class="mb-8">
          <div class="flex items-baseline gap-1">
            <span class="text-5xl font-bold text-on-surface">$49</span>
            <span class="text-on-surface-variant font-label text-sm">/mo</span>
          </div>
        </div>
        <div class="space-y-4 mb-10 flex-grow">
          <div class="flex items-center gap-3 text-sm text-on-surface">
            <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">bolt</span>
            <span class="font-bold">Priority API Access</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-on-surface">
            <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">visibility_off</span>
            <span class="font-bold">Private Logs & Analytics</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-on-surface">
            <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">all_inclusive</span>
            <span class="font-bold">Unlimited Tasks</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-on-surface">
            <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">monitoring</span>
            <span class="font-bold">Advanced Telemetry</span>
          </div>
        </div>
        <button class="w-full py-4 bg-primary-container text-on-primary rounded-lg font-extrabold text-sm shadow-[0_0_15px_rgba(0,240,255,0.4)] hover:brightness-110 transition-all">
          Upgrade to Pro
        </button>
      </div>

      <!-- Enterprise Tier -->
      <div class="metal-card rounded-xl p-8 flex flex-col glow-overlay">
        <div class="mb-8">
          <span class="font-label text-xs uppercase tracking-widest text-secondary">Custom Cluster</span>
          <h3 class="font-headline text-3xl font-bold mt-2">Enterprise</h3>
        </div>
        <div class="mb-8">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-bold text-on-surface">Custom</span>
          </div>
        </div>
        <div class="space-y-4 mb-10 flex-grow">
          <div class="flex items-center gap-3 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-secondary text-lg">shield</span>
            <span>SOC2 Compliance Package</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-secondary text-lg">dns</span>
            <span>Dedicated Bare Metal Nodes</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-secondary text-lg">support_agent</span>
            <span>24/7 Human-in-the-loop</span>
          </div>
        </div>
        <button class="w-full py-3 bg-surface-container-highest border border-outline-variant/15 rounded-lg font-bold text-sm hover:bg-surface-container-high transition-colors">
          Contact Forge
        </button>
      </div>
    </div>

    <!-- Comparison Table -->
    <section class="mb-32">
      <div class="mb-12">
        <h2 class="font-headline text-3xl font-bold">Deep Specifications</h2>
        <div class="h-1 w-20 bg-primary-container mt-4"></div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-y-2">
          <thead>
            <tr class="text-on-surface-variant font-label text-[10px] uppercase tracking-widest">
              <th class="px-6 py-4">Capability</th>
              <th class="px-6 py-4">Hobby</th>
              <th class="px-6 py-4 text-primary">Pro</th>
              <th class="px-6 py-4">Enterprise</th>
            </tr>
          </thead>
          <tbody class="text-sm">
            <tr class="bg-surface-container-low/50">
              <td class="px-6 py-5 font-bold border-l-2 border-transparent">Concurrent Agents</td>
              <td class="px-6 py-5">2 Units</td>
              <td class="px-6 py-5 text-primary">Unlimited</td>
              <td class="px-6 py-5">Unlimited + Sharding</td>
            </tr>
            <tr class="bg-surface-container-low/50">
              <td class="px-6 py-5 font-bold border-l-2 border-primary-container">Telemetry Frequency</td>
              <td class="px-6 py-5">60s Polling</td>
              <td class="px-6 py-5 text-primary">Real-time (0.1s)</td>
              <td class="px-6 py-5">Custom Precision</td>
            </tr>
            <tr class="bg-surface-container-low/50">
              <td class="px-6 py-5 font-bold border-l-2 border-transparent">Storage Retention</td>
              <td class="px-6 py-5">24 Hours</td>
              <td class="px-6 py-5 text-primary">90 Days</td>
              <td class="px-6 py-5">Eternal Archive</td>
            </tr>
            <tr class="bg-surface-container-low/50">
              <td class="px-6 py-5 font-bold border-l-2 border-transparent">API Rate Limit</td>
              <td class="px-6 py-5">100 req/hr</td>
              <td class="px-6 py-5 text-primary">10k req/min</td>
              <td class="px-6 py-5">Burst-Optimized</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="max-w-4xl mx-auto">
      <h2 class="font-headline text-3xl font-bold mb-12 text-center">Frequently Queried</h2>
      <div class="space-y-4">
        <div class="bg-surface-container-low p-6 rounded-lg ghost-border">
          <h4 class="font-headline text-lg font-bold mb-2">How is "Usage" measured?</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Usage is calculated by active compute hours per agent instance. Hobby users are capped at 5 daily tasks, while Pro users have zero throttle on task volume within the shared cluster.
          </p>
        </div>
        <div class="bg-surface-container-low p-6 rounded-lg ghost-border">
          <h4 class="font-headline text-lg font-bold mb-2">Can I downgrade from Pro at any time?</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Affirmative. Billing cycles are monthly. Upon cancellation, your private logs will be archived for 7 days before being purged from the high-security cluster.
          </p>
        </div>
        <div class="bg-surface-container-low p-6 rounded-lg ghost-border">
          <h4 class="font-headline text-lg font-bold mb-2">What qualifies for Enterprise?</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Teams requiring HIPAA/SOC2 compliance, private cloud deployments, or sub-millisecond telemetry response times are automatically routed to our Enterprise Architects.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA / Tagline Section -->
    <section class="mt-32 text-center pb-20">
      <div class="bg-surface-container-highest/30 p-16 rounded-3xl backdrop-blur-md ghost-border">
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold mb-6">Don't just compete. <span class="text-primary">Dominate.</span></h2>
        <p class="text-on-surface-variant mb-10 max-w-lg mx-auto">Join 12,000+ engineers building on the titanium standard of AI automation.</p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
          <button class="bg-primary-container text-on-primary px-8 py-4 rounded-lg font-bold text-lg shadow-[0_0_25px_rgba(0,240,255,0.2)]">Get Started Now</button>
          <button class="bg-surface px-8 py-4 rounded-lg font-bold text-lg ghost-border hover:bg-surface-container-high transition-colors">Review Documentation</button>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
