---
const navItems = [
  { label: 'Benchmarks', href: '/benchmarks' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
  { label: 'Community', href: '#' },
];

const { currentPath = Astro.url.pathname } = Astro.props;
---

<nav class="fixed top-0 w-full z-50 bg-surface/70 backdrop-blur-xl flex justify-between items-center px-6 py-3 shadow-[0_4px_20px_rgba(0,240,255,0.05)]">
  <a href="/" class="text-xl font-bold tracking-tighter text-primary-container font-headline">
    SHINYMETAL.BOT
  </a>
  
  <div class="hidden md:flex items-center space-x-8 font-headline">
    {navItems.map((item) => (
      <a 
        href={item.href} 
        class:list={[
          "transition-colors text-sm uppercase tracking-tight",
          currentPath === item.href ? "text-primary-container" : "text-on-surface-variant hover:text-primary"
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>

  <button class="bg-primary-container text-on-primary px-5 py-2 rounded-lg font-bold text-sm hover:bg-surface-tint transition-all duration-300 scale-95 active:scale-90 shadow-[0_0_15px_rgba(0,240,255,0.3)]">
    Connect Agent
  </button>
  
  <div class="bg-gradient-to-r from-transparent via-primary-container/20 to-transparent h-[1px] w-full absolute bottom-0"></div>
</nav>
