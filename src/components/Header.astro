---
const navItems = [
  { label: 'Arena', href: '/' },
  { label: 'Leaderboard', href: '/benchmarks' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Manifesto', href: '/about' },
  { label: 'Transmissions', href: '#' },
];

const { currentPath = Astro.url.pathname } = Astro.props;
---

<nav class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-zinc-950/80 backdrop-blur-xl border-b-2 border-fuchsia-900/50 glow-sm shadow-[0_0_15px_rgba(255,0,255,0.15)]">
  <div class="text-2xl font-black text-fuchsia-500 italic tracking-tighter font-headline uppercase">
    SHINYMETAL.BOT
  </div>
  
  <div class="hidden md:flex gap-8 items-center font-headline uppercase tracking-tighter tabular-nums">
    {navItems.map((item) => (
      <a 
        href={item.href} 
        class:list={[
          "transition-all duration-75 hover:bg-fuchsia-500/10 hover:skew-x-2 px-2 py-1",
          currentPath === item.href ? "text-fuchsia-400 border-b-2 border-fuchsia-500 pb-1" : "text-zinc-500 hover:text-fuchsia-300"
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>

  <button class="bg-primary-container text-on-primary-container font-black px-6 py-2 uppercase skew-x-[-12deg] active:scale-95 brightness-125 transition-all">
    <span class="inline-block skew-x-[12deg]">Connect Identity</span>
  </button>
</nav>
